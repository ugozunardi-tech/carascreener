    "node-cache": "^5.1.2",
    "openai": "^4.28.0",
    "yahoo-finance2": "^3.13.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
